// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String @id @default(uuid())
  email         String @unique
  password      String
  username      String @unique
  displayName   String
  profileImgUrl String
  headerImgUrl  String

  posts   Post[]
  likes   PostLike[]
  folders BookmarkFolder[]

  followers  Follow[] @relation("Follower")
  followings Follow[] @relation("Following")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Follow {
  followerId String
  follower   User   @relation("Follower", fields: [followerId], references: [id])

  followingId String
  following   User   @relation("Following", fields: [followingId], references: [id])

  isMuted    Boolean @default(false)
  isFavorite Boolean @default(false)

  createdAt DateTime @default(now())

  @@id([followerId, followingId], name: "followId")
}

enum PostState {
  PUBLIC
  PRIVATE
  FAVORITE
  NOTICE
  DELETED
  ERROR
}

model Post {
  id      Int       @id @default(autoincrement())
  state   PostState @default(PUBLIC)
  content String

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  rootPostId Int?
  rootPost   Post?  @relation("RootPost", fields: [rootPostId], references: [id])
  rootOf     Post[] @relation("RootPost")

  parentPostId Int?
  parentPost   Post?  @relation("ParentPost", fields: [rootPostId], references: [id])
  replies      Post[] @relation("ParentPost")

  images    PostImage[]
  likes     PostLike[]
  bookmarks Bookmark[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PostImage {
  id     String @id @default(uuid())
  imgUrl String

  postId Int
  post   Post @relation(fields: [postId], references: [id])
}

model PostLike {
  userId String
  user   User   @relation(fields: [userId], references: [id])
  postId Int
  post   Post   @relation(fields: [postId], references: [id])

  @@id([userId, postId], name: "likeId")
}

model BookmarkFolder {
  id          String @id @default(uuid())
  name        String
  description String

  userId String
  user   User   @relation(fields: [userId], references: [id])

  bookmarks Bookmark[]
}

model Bookmark {
  folderId String
  folder   BookmarkFolder @relation(fields: [folderId], references: [id])
  postId   Int
  post     Post           @relation(fields: [postId], references: [id])

  @@id([folderId, postId], name: "bookmarkId")
}
